---
import HomeCategoryRail from "../components/HomeCategoryRail.astro";
import HomeInfiniteFeed from "../components/HomeInfiniteFeed.astro";
import HomePagedFeed from "../components/HomePagedFeed.astro";
import HomeSidebar from "../components/HomeSidebar.astro";
import HalorumLayout from "../layouts/HalorumLayout.astro";
---

<HalorumLayout
  page="home"
  titleExpression="${site.title}"
  descriptionExpression="${site.subtitle}"
  contentClass="home-content"
  showFooterInRight
>
  <HomeCategoryRail />
  <th:block
    th:with="sourcePosts=${posts}, homePage=${sourcePosts == null ? 1 : #conversions.convert(sourcePosts.page ?: 1, 'java.lang.Integer')}, homePageSize=${#conversions.convert(theme.config.sidebar.homePostPageSize ?: 15, 'java.lang.Integer')}, homeLoadMode=${theme.config.sidebar.homePostLoadMode ?: 'button'}, posts=${postFinder.list({page: homePage, size: homePageSize, sort: {'spec.pinned,desc', 'spec.publishTime,desc', 'metadata.creationTimestamp,desc'}})}"
  >
    <th:block th:if="${homeLoadMode != 'infinite'}">
      <HomePagedFeed />
    </th:block>
    <th:block th:if="${homeLoadMode == 'infinite'}">
      <HomeInfiniteFeed />
    </th:block>
  </th:block>
  <HomeSidebar />
</HalorumLayout>

<style is:inline>
  .home-content {
    align-items: flex-start;
  }

  .home-content .main-left {
    max-width: calc(100% - 498px);
  }

  @media screen and (min-width: 1181px) {
    .home-content {
      margin-left: -76px;
      margin-right: -76px;
    }
  }

  @media screen and (max-width: 1180px) {
    .home-content .main-left {
      max-width: calc(100% - 470px);
    }
  }

  @media screen and (max-width: 1000px) {
    .home-content .main-left {
      max-width: calc(100% - 170px);
    }
  }

  @media screen and (max-width: 900px) {
    .home-content .main-left {
      max-width: none;
    }
  }
</style>
