---
import HalorumLayout from "../layouts/HalorumLayout.astro";
---

<HalorumLayout
  page="category"
  titleExpression="|标签 - ${site.title}|"
  descriptionExpression="${site.subtitle}"
  contentClass="category-content"
  showCategoryNav
>
  <div class="main-left">
    <div class="category-tips">
      <div class="category-tips-content">全部标签</div>
    </div>
    <div class="article-card-wrap">
      <article class="article-card" th:each="tag : ${tags}" th:data-link="${tag.status.permalink}">
        <div class="article-card-body">
          <div class="article-card-main">
            <h2 class="article-card-title">
              <a th:href="@{${tag.status.permalink}}" th:text="${tag.spec.displayName}"></a>
            </h2>
            <div class="article-card-footer">
              <span class="article-card-footer-item" th:text="|${tag.postCount} 篇文章|"></span>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
  <div class="main-right"></div>
</HalorumLayout>
